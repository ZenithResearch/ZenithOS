output-file-map.json

# Agent/local state
.hermes/
.pytest_cache/
.venv*/
__pycache__/
*.pyc

# Local secrets/runtime state
.env
.env.*
!.env.example
!.env.template
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
*.log
/logs/
/sessions/
/auth/

# OS/editor noise
.DS_Store
*.swp
*.tmp
